{
  "name": "@allure-station/server",
  "version": "0.0.0",
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "start:worker": "tsx src/worker-main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts"
  },
  "dependencies": {
    "@allure-station/shared": "workspace:*",
    "@allure-station/worker": "workspace:*",
    "@aws-sdk/client-s3": "3.1063.0",
    "@aws-sdk/lib-storage": "3.1063.0",
    "@fastify/multipart": "8.3.0",
    "@fastify/static": "7.0.4",
    "@libsql/client": "0.14.0",
    "drizzle-orm": "0.36.0",
    "fastify": "4.28.1",
    "ioredis": "5.10.1",
    "mrmime": "2",
    "nanoid": "5.0.7",
    "pg": "8.21.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/pg": "8.11.11",
    "drizzle-kit": "0.28.0",
    "tsx": "4.19.2"
  }
}
